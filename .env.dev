# 开发环境：本地只启动前端项目，依赖开发环境（后端、APP）
NODE_ENV=development

VITE_DEV=true

# 本机从内网导出项目时没有后端：由 src/mock 接管所有 Axios 请求。
# 接入真实开发后端时改为 false 并重启 Vite。
VITE_USE_MOCK=true

# 请求路径
