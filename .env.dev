#VITE_BASE_URL='/gateway-service' #打包用的域名
# VITE_BASE_URL='https://crms-sit.ncbank.cn/SCFMOS/gateway-http-80' # dev
#VITE_BASE_URL='https://crms.ncbank.cn/SCFMOS/gateway-http-80' # pp

# 本地后端端口
 # VITE_BASE_URL='http://192.168.170.124:48080' 后台1
 # VITE_BASE_URL='http://192.168.170.41:48080' # 尚鑫欢
#  #VITE_BASE_URL='http://192.168.170.58:48080' # 张海洋
 # VITE_BASE_URL='http://192.168.168.26:48080' # 鲍天然
#VITE_BASE_URL='http://192.168.170.124:48080' # 张海洋的同桌
